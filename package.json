{
  "name": "travel-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "test": "jest",
    "test:e2e:install": "npx playwright install",
    "test:e2e": "npx playwright test",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:amap": "tsx scripts/seed-amap.ts",
