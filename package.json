    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.16.1",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^29",
